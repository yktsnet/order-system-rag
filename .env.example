# Azure Document Intelligence 設定
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<your-resource-name>.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your_document_intelligence_api_key_here

# Azure AI Search 設定
AZURE_SEARCH_SERVICE_ENDPOINT=https://<your-service-name>.search.windows.net
AZURE_SEARCH_ADMIN_KEY=your_search_admin_key_here
AZURE_SEARCH_INDEX_NAME=order-system-rag-index

# Gemini API 設定 (embedding・生成・ルーティング判定に使用)
GEMINI_API_KEY=your_gemini_api_key_here

# デプロイ用
DEPLOY_HOST=<ssh-host>
DEPLOY_USER=<ssh-user>
CORS_ORIGINS=https://<your-domain>
